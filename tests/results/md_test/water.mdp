integrator  = md
dt          = 0.002
nsteps      = 10000
nstenergy   = 100
nstlog      = 100

cutoff-scheme   = Verlet
nstlist         = 10
rlist           = 0.7
coulombtype     = cutoff
rcoulomb        = 0.7
vdwtype         = cutoff
rvdw            = 0.7

tcoupl  = v-rescale
tc-grps = System
tau_t   = 0.1
ref_t   = 300

constraints = h-bonds
